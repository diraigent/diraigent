FROM nginx:alpine

COPY nginx.conf /etc/nginx/nginx.conf
COPY public/ /usr/share/nginx/html/

LABEL org.opencontainers.image.title="diraigent-landing" \
      org.opencontainers.image.description="Diraigent landing page — static HTML/CSS" \
      org.opencontainers.image.vendor="Zivue AS" \
      org.opencontainers.image.url="https://www.diraigent.com" \
      org.opencontainers.image.source="https://www.diraigent.com"

EXPOSE 80
