# ── Stage 1: build orchestra from Rust source ──────────────
FROM --platform=linux/amd64 rust:1.93-bookworm AS builder
WORKDIR /build

ARG TARGETARCH
ARG DIRAIGENT_VERSION

# Install cross-compilation tools for arm64 (only when needed)
RUN if [ "$TARGETARCH" = "arm64" ]; then \
      dpkg --add-architecture arm64 && \
      apt-get update && apt-get install -y --no-install-recommends \
        gcc-aarch64-linux-gnu libc6-dev-arm64-cross \
        libssl-dev:arm64 && \
      rustup target add aarch64-unknown-linux-gnu && \
      rm -rf /var/lib/apt/lists/*; \
    fi

# ── Layer 1: workspace manifests only (cached unless Cargo.toml/lock change) ──
COPY Cargo.toml Cargo.lock ./

# Copy crate manifests (but not source code yet)
COPY libs/common-rust/diraigent-types/Cargo.toml libs/common-rust/diraigent-types/Cargo.toml
COPY libs/common-rust/shared-utils/Cargo.toml libs/common-rust/shared-utils/Cargo.toml
COPY libs/common-rust/shared-build-utils/Cargo.toml libs/common-rust/shared-build-utils/Cargo.toml
COPY apps/orchestra/Cargo.toml apps/orchestra/Cargo.toml

# Rewrite workspace to only include these crates
RUN sed -i '/^members = \[/,/^\]/c\members = ["libs/common-rust/*", "apps/orchestra"]' Cargo.toml && \
    sed -i '/^exclude = \[/,/^\]/d' Cargo.toml

# Create stub source files so cargo can resolve the dependency graph
RUN mkdir -p libs/common-rust/diraigent-types/src && echo "" > libs/common-rust/diraigent-types/src/lib.rs && \
    mkdir -p libs/common-rust/shared-utils/src && echo "" > libs/common-rust/shared-utils/src/lib.rs && \
    mkdir -p libs/common-rust/shared-build-utils/src && echo "" > libs/common-rust/shared-build-utils/src/lib.rs && \
    mkdir -p apps/orchestra/src && echo "fn main(){}" > apps/orchestra/src/main.rs && \
    echo "fn main(){}" > apps/orchestra/src/cli.rs

# Build dependencies only (this layer is cached until Cargo.toml/lock change)
RUN if [ "$TARGETARCH" = "arm64" ]; then \
      PKG_CONFIG_ALLOW_CROSS=1 \
      PKG_CONFIG_PATH=/usr/lib/aarch64-linux-gnu/pkgconfig \
      CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=aarch64-linux-gnu-gcc \
      cargo build --release --target aarch64-unknown-linux-gnu -p diraigent-orchestra 2>/dev/null || true; \
    else \
      cargo build --release -p diraigent-orchestra 2>/dev/null || true; \
    fi

# ── Layer 2: actual source code (rebuilds only app code, deps are cached) ──
COPY libs/ libs/
COPY apps/orchestra/ apps/orchestra/

# Touch source files to ensure cargo rebuilds them (not the cached deps)
RUN touch libs/common-rust/diraigent-types/src/lib.rs \
          libs/common-rust/shared-utils/src/lib.rs \
          apps/orchestra/src/main.rs \
          apps/orchestra/src/cli.rs

RUN if [ "$TARGETARCH" = "arm64" ]; then \
      PKG_CONFIG_ALLOW_CROSS=1 \
      PKG_CONFIG_PATH=/usr/lib/aarch64-linux-gnu/pkgconfig \
      CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER=aarch64-linux-gnu-gcc \
      cargo build --release --target aarch64-unknown-linux-gnu -p diraigent-orchestra && \
      cp target/aarch64-unknown-linux-gnu/release/orchestra /usr/local/bin/orchestra && \
      cp target/aarch64-unknown-linux-gnu/release/agent-cli /usr/local/bin/agent-cli; \
    else \
      cargo build --release -p diraigent-orchestra && \
      cp target/release/orchestra /usr/local/bin/orchestra && \
      cp target/release/agent-cli /usr/local/bin/agent-cli; \
    fi

# Bake version: use build arg if provided, otherwise build timestamp
RUN if [ -n "$DIRAIGENT_VERSION" ]; then \
      echo "$DIRAIGENT_VERSION" > /tmp/diraigent_version; \
    else \
      echo "dev-$(date -u +%Y%m%d-%H%M)" > /tmp/diraigent_version; \
    fi

# ── Stage 2: runtime ──────────────────────────────────────────
FROM node:22-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl git ca-certificates util-linux \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (still needed — orchestra spawns it as a worker)
RUN npm install -g @anthropic-ai/claude-code

# Security: run as non-root user
RUN groupadd --system --gid 1001 appgroup && \
    useradd --system --uid 1001 --gid appgroup --create-home appuser

WORKDIR /app

# Orchestra and CLI binaries
COPY --from=builder --chown=appuser:appgroup /usr/local/bin/orchestra /usr/local/bin/orchestra
COPY --from=builder --chown=appuser:appgroup /usr/local/bin/agent-cli /usr/local/bin/agent-cli
COPY --from=builder /tmp/diraigent_version /etc/diraigent_version

# Agent docs
COPY --from=builder --chown=appuser:appgroup /build/apps/orchestra/CLAUDE.md ./
RUN chown appuser:appgroup /app && mkdir -p logs /repo && chown appuser:appgroup logs /repo

USER appuser

# Defaults — override at runtime via env or docker-compose
ENV DIRAIGENT_API_URL=http://api:8082/v1 \
    MAX_WORKERS=3 \
    PROJECTS_PATH=/projects \
    SERVICE_NAME=diraigent-orchestra

LABEL org.opencontainers.image.title="diraigent-orchestra" \
      org.opencontainers.image.description="AI agent orchestrator — spawns Claude Code workers in isolated git worktrees" \
      org.opencontainers.image.vendor="Zivue AS" \
      org.opencontainers.image.url="https://www.diraigent.com" \
      org.opencontainers.image.source="https://www.diraigent.com"

ENTRYPOINT ["sh", "-c", "export DIRAIGENT_VERSION=${DIRAIGENT_VERSION:-$(cat /etc/diraigent_version)}; exec orchestra"]
