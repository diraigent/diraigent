# ── Required ──────────────────────────────────────────────────────

# Diraigent API base URL
DIRAIGENT_API_URL=http://localhost:8082/v1

# Agent API key (dak_...) — issued by POST /v1/agents during onboard.
# Long-lived, no refresh needed.
DIRAIGENT_API_TOKEN=dak_...

# Agent UUID — set automatically by ./onboard.sh
AGENT_ID=<uuid>

# ── Optional ──────────────────────────────────────────────────────

# Base directory where project repos are located.
# Defaults to ~/diraigent/projects if not set.
# PROJECTS_PATH=/path/to/repos

# Max concurrent Claude Code workers (default: 3)
# MAX_WORKERS=3

# Default model for workers (overridable per-task via context)
# WORKER_MODEL=claude-opus-4-6

# Loki log shipping (omit to disable)
# LOKI_URL=http://localhost:3100
# LOKI_ENV=dev
