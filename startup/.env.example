# ── Diraigent Docker Compose ──────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── API ───────────────────────────────────────────────────────────

# Dev mode: skip real JWT auth, use this user ID for all requests.
# Remove in production and set AUTH_JWKS_URL instead.
DEV_USER_ID=00000000-0000-0000-0000-000000000001

# OIDC / JWT auth (production)
# AUTH_ISSUER=https://auth.example.com/application/o/diraigent/
# AUTH_JWKS_URL=https://auth.example.com/application/o/diraigent/jwks/

# Allowed CORS origins (comma-separated)
# CORS_ORIGINS=https://app.example.com

# Loki log shipping (optional)
# LOKI_URL=http://loki:3100
# LOKI_ENV=dev

# ── Orchestra ─────────────────────────────────────────────────────

# Agent UUID — auto-created by start.sh, or set manually
# AGENT_ID=

# Git repo URL that orchestra clones into the worker volume
# GIT_REPO_URL=<https://your-repo-url.git>

# Max concurrent Claude Code workers (default: 3)
# MAX_WORKERS=3
